#header
    @extend $block
    background: var(--color-surface)
    border-bottom: 1px solid var(--color-border)
    position: relative
    z-index: 10
    a, a:visited,
    button
        white-space: nowrap
        transition: 0.2s ease
        color: var(--color-default)
    a:hover,
    button:hover,
    button:focus
        color: var(--color-link)
        text-decoration: none

header-block-padding = (header-height - logo-height) / 2
if header-block-padding < 0
    header-block-padding = 0

.header-inner
    position: relative

#header-main
    .header-main-inner
        display: flex
        align-items: center
        min-height: header-height

#logo
    display: inline-flex
    align-items: center
    flex: 0 0 auto
    min-height: header-height
    padding: header-block-padding 15px
    line-height: logo-height
    .logo
        flex: 0 0 auto
        margin-right: 8px
        display: inline-block
    .site-title
        font-size: 16px
        display: inline-block
        line-height: logo-height
        font-weight: 600

#header-title
    text-align: center
    height: logo-height
    position: absolute
    top: 50%
    left: 0
    margin-top: logo-height * -0.5

.header-sub
    border-top: 1px solid var(--color-border)

.header-actions
    display: flex
    align-items: center
    flex: 0 0 auto
    min-height: header-height
    margin-left: auto
    gap: 4px

$nav-link
    display: inline-flex
    align-items: center
    min-height: header-height
    padding: 0 15px

.nav-icon
    display: inline-flex
    align-items: center
    justify-content: center
    width: logo-height
    height: logo-height
    font-size: font-size
    position: relative
    cursor: pointer

.main-nav-link
    @extend $nav-link
    font-weight: 500
    border-bottom: 2px solid transparent
    &.is-active
        color: var(--color-link)
        border-bottom-color: var(--color-link)

#main-nav
    display: flex
    align-items: center
    min-height: header-height
    @media mq-mobile
        display: none
    @media mq-mini
        display: none

#main-nav-mobile
    overflow: hidden
    @media mq-tablet
        display: none
    @media mq-normal
        display: none
    .mobile-menu
        display: flex
        align-items: center
        flex-wrap: wrap
        min-height: header-sub-height
        gap: 2px
    .main-nav-link
        flex: 0 0 auto
        min-height: header-sub-height
        line-height: header-sub-height
        padding: 0 10px
        border-bottom-width: 2px
        @media mq-mini
            flex: 1 1 auto
            justify-content: center
            min-width: 68px
            padding: 0 6px

#sub-nav
    @media mq-normal
        display: none
    display: flex
    align-items: center
    min-height: header-height
    padding: 0 15px
    #profile-nav
        #profile-anchor
            display: inline-flex
            align-items: center
            border: none
            background: none
            cursor: pointer
            font: font-size font-sans
            height: logo-height
            line-height: logo-height
        .avatar
            width: logo-height
            height: logo-height
            margin-right: 8px
        .fa-solid,
        .fa-regular,
        .fa-brands
            line-height: 1

#search-form-wrap
    display: flex
    align-items: center
    min-height: header-height
    padding: 0 8px
    .search-form
        position: relative
        display: flex
        align-items: center

.search-form-submit
    display: inline-flex
    align-items: center
    justify-content: center
    width: 34px
    height: 34px
    margin-left: 4px
    padding: 0
    border: 1px solid var(--color-border)
    border-radius: 50%
    color: var(--color-default)
    background: var(--color-surface)
    cursor: pointer

.search-form-trigger
    @extend .nav-icon
    border: none
    border-radius: 50%
    background: none
    font: font-size font-sans
    color: var(--color-default)
    &:hover,
    &:focus
        outline: none
        background: rgba(56, 183, 234, 0.08)

.mobile-menu-trigger
    @extend .nav-icon
    display: none
    border: none
    border-radius: 50%
    background: none
    font: font-size font-sans
    .mobile-menu-icon
        display: inline-flex
    .mobile-menu-icon-close
        display: none
    &[aria-expanded="true"]
        .mobile-menu-icon-open
            display: none
        .mobile-menu-icon-close
            display: inline-flex
    &:hover,
    &:focus
        background: rgba(9, 105, 218, 0.08)
    @media mq-mini
        display: inline-flex
    @media mq-mobile
        display: inline-flex

.mobile-menu-panel
    display: none
    border-top: 1px solid var(--color-border)
    background: var(--color-surface)
    box-shadow: 0 8px 18px rgba(16, 24, 40, 0.08)
    &[hidden]
        display: none !important
    @media mq-mini
        display: block
    @media mq-mobile
        display: block
    @media mq-tablet
        display: none
    @media mq-normal
        display: none

.mobile-menu-drawer
    padding-top: 12px
    padding-bottom: 14px

.mobile-menu-heading
    display: block
    margin: 0 0 8px
    color: var(--color-grey)
    font-size: 12px
    font-weight: 700
    text-transform: uppercase

.mobile-menu-list
    display: grid
    grid-template-columns: repeat(2, minmax(0, 1fr))
    gap: 4px
    .main-nav-link
        min-height: 40px
        padding: 0 10px
        border: 1px solid transparent
        border-radius: var(--radius-default)
        justify-content: flex-start
        overflow: hidden
        text-overflow: ellipsis
        &:hover,
        &.is-active
            border-color: var(--color-border)
            background: var(--color-background)

.search-form-input,
.search-form-input.ins-search-input,
.search-form-input.st-ui-search-input,
.search-form-input.st-default-search-input
    -webkit-appearance: textarea
    appearance: textarea
    padding: 0
    width: 200px
    box-shadow: none
    color: var(--color-default)
    transition: 0.2s ease
    box-sizing: border-box
    height: auto !important
    line-height: line-height
    outline: none !important
    background: none !important
    font: font-size font-sans
    border: 1px solid var(--color-border) !important
    &:focus
        border-color: var(--color-link) !important
    &::-webkit-search-results-decoration
    &::-webkit-search-cancel-button
        -webkit-appearance: none
