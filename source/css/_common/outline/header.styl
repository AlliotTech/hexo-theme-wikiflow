#header
    @extend $block
    background: var(--color-surface)
    position: relative
    a, a:visited,
    button
        white-space: nowrap
        transition: 0.2s ease
        color: var(--color-default)
    a:hover,
    button:hover,
    button:focus
        color: var(--color-link)

header-block-padding = (header-height - logo-height) / 2
if header-block-padding < 0
    header-block-padding = 0

.header-inner
    position: relative

#header-main
    .header-main-inner
        display: flex
        align-items: center
        min-height: header-height

#logo
    display: inline-flex
    align-items: center
    flex: 0 0 auto
    min-height: header-height
    padding: header-block-padding 15px
    line-height: logo-height
    .logo
        flex: 0 0 auto
        margin-right: 8px
        display: inline-block
    .site-title
        font-size: 16px
        display: inline-block
        line-height: logo-height
        font-weight: 600

#header-title
    text-align: center
    height: logo-height
    position: absolute
    top: 50%
    left: 0
    margin-top: logo-height * -0.5

.header-sub
    border-top: 1px solid var(--color-border)

.header-actions
    display: flex
    align-items: center
    flex: 0 0 auto
    min-height: header-height
    margin-left: auto

$nav-link
    display: inline-flex
    align-items: center
    min-height: header-height
    padding: 0 15px

.nav-icon
    display: inline-flex
    align-items: center
    justify-content: center
    width: logo-height
    height: logo-height
    font-size: font-size
    position: relative
    cursor: pointer

.main-nav-link
    @extend $nav-link
    font-weight: 300

#main-nav
    display: flex
    align-items: center
    min-height: header-height
    @media mq-mobile
        display: none
    @media mq-mini
        display: none

#main-nav-mobile
    overflow-y: hidden
    overflow-x: auto
    @media mq-tablet
        display: none
    @media mq-normal
        display: none
    .mobile-menu
        display: flex
        align-items: center
        min-height: header-sub-height
    .main-nav-link
        flex: 0 0 auto
        min-height: header-sub-height
        line-height: header-sub-height
        padding: 0 12px

#sub-nav
    @media mq-normal
        display: none
    display: flex
    align-items: center
    min-height: header-height
    padding: 0 15px
    #profile-nav
        #profile-anchor
            display: inline-flex
            align-items: center
            border: none
            background: none
            cursor: pointer
            font: font-size font-sans
            height: logo-height
            line-height: logo-height
        .avatar
            width: logo-height
            height: logo-height
            margin-right: 8px
        .fa
            line-height: 1

#search-form-wrap
    display: flex
    align-items: center
    min-height: header-height
    padding: 0 15px
    .search-form
        position: relative

.search-form-trigger
    @extend .nav-icon
    border: none
    border-radius: 50%
    background: none
    font: font-size font-sans
    color: var(--color-default)
    &:before
        content: '\f002'
        font-family: 'FontAwesome'
    &:hover,
    &:focus
        outline: none
        background: rgba(56, 183, 234, 0.08)

.search-form-input,
.search-form-input.ins-search-input,
.search-form-input.st-ui-search-input,
.search-form-input.st-default-search-input
    -webkit-appearance: textarea
    appearance: textarea
    padding: 0
    width: 200px
    box-shadow: none
    color: var(--color-default)
    transition: 0.2s ease
    box-sizing: border-box
    height: auto !important
    line-height: line-height
    outline: none !important
    background: none !important
    font: font-size font-sans
    border: 1px solid var(--color-border) !important
    &:focus
        border-color: var(--color-link) !important
    &::-webkit-search-results-decoration
    &::-webkit-search-cancel-button
        -webkit-appearance: none
