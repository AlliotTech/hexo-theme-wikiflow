#sidebar
    grid-area: unquote("sidebar")
    min-width: 0
    width: 100%
    @media mq-mini
        display: contents
    @media mq-mobile
        display: contents
    @media mq-normal
        display: flex
        flex-direction: column
        position: sticky
        top: 20px
        max-height: calc(100vh - 40px)
        overflow-x: hidden
        overflow-y: auto
        width: 100%
    @media mq-tablet
        display: flex
        flex-direction: column
        position: sticky
        top: 20px
        max-height: calc(100vh - 40px)
        overflow-x: hidden
        overflow-y: auto
        width: 100%
