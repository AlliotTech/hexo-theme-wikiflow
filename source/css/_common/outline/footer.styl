#footer
    padding: 20px 0
    border-top: 1px solid var(--color-border)
    color: var(--color-default)
    font-size: font-size + 2
    text-align: center
    .outer
        margin-bottom: 0
    a
        color: var(--color-link)
        text-decoration: none
        &:hover
            text-decoration: underline

#footer-info
    line-height: line-height
    font-size: 0.85em
