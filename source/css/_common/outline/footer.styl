#footer
    padding: 20px 0
    border-top: 1px solid var(--color-border)
    color: var(--color-default)
    font-size: font-size + 2
    text-align: center
    .outer
        margin-bottom: 0
    a
        color: var(--color-link)
        text-decoration: none
        &:hover
            text-decoration: underline

#footer-info
    line-height: line-height
    font-size: 0.85em
    .beian
        margin-top: 0.35em
        a
            display: inline-flex
            align-items: center
            margin: 0 0.35em
            vertical-align: middle
    .beian-gongan img
        width: 14px
        height: 14px
        margin-right: 0.25em
