// Insight Search Styles
ins-container-width = 760px
ins-text-grey = #5f6b76
ins-border-grey = #d7dee5
ins-background-grey = #f6f8fa
ins-background-blue = #0969da

$ins-full-screen
    top: 0
    left: 0
    margin: 0
    width: 100%
    height: 100%

.ins-search
    display: none
    &.show
        display: block

.ins-selectable
    cursor: pointer

.ins-search-mask,
.ins-search-container
    position: fixed

.ins-search-mask
    top: 0
    left: 0
    width: 100%
    height: 100%
    z-index: 100
    background: rgba(15,23,42,0.42)

.ins-input-wrapper
    position: relative

.ins-search-input
    width: 100%
    border: none
    outline: none
    font-size: 16px
    box-shadow: none
    font-weight: 400
    border-radius: 0
    background: var(--color-surface)
    line-height: 20px
    box-sizing: border-box
    padding: 12px 28px 12px 20px
    border-bottom: 1px solid ins-border-grey
    font-family: font-sans

.ins-close
    top: 50%
    right: 6px
    width: 20px
    height: 20px
    font-size: 16px
    margin-top: -11px
    position: absolute
    text-align: center
    display: inline-block
    border: none
    background: none
    color: var(--color-grey)
    cursor: pointer
    &:hover
        color: ins-background-blue

.ins-search-container
    left: 50%
    top: 100px
    z-index: 101
    bottom: 100px
    box-sizing: border-box
    width: unquote('min(760px, calc(100vw - 32px))')
    margin-left: unquote('calc(min(760px, calc(100vw - 32px)) / -2)')
    overflow: hidden
    border-radius: var(--radius-default)
    background: ins-background-grey
    box-shadow: 0 16px 40px rgba(15,23,42,0.18)
    @media screen and (max-width: 559px), screen and (max-height: 479px)
        top: 0
        left: 0
        margin: 0
        width: 100%
        height: 100%
        background: ins-background-grey

.ins-section-wrapper
    left: 0
    right: 0
    top: 45px
    bottom: 0
    overflow-y: auto
    position: absolute

.ins-section-container
    position: relative
    background: ins-background-grey

.ins-section
    font-size: 14px
    line-height: 1.45
    .ins-section-header,
    .ins-search-item
        padding: 8px 15px
    .ins-section-header
        color: ins-text-grey
        border-bottom: 1px solid ins-border-grey
        font-size: 12px
        font-weight: 700
        text-transform: uppercase
    .ins-slug
        display: block
        margin: 3px 0 0 22px
        color: ins-text-grey
        font-size: 12px
        overflow: hidden
        text-overflow: ellipsis
        white-space: nowrap
    .ins-search-item
        border-bottom: 1px solid ins-border-grey
        outline: none
        header,
        .ins-search-preview
            overflow: hidden
            text-overflow: ellipsis
        header
            color: var(--color-default)
            font-weight: 600
            .fa
                margin-right: 8px
        .ins-search-preview
            display: -webkit-box
            height: auto
            max-height: 3em
            font-size: 12px
            color: ins-text-grey
            line-height: 1.5
            margin: 6px 0 0 22px
            white-space: normal
            -webkit-box-orient: vertical
            -webkit-line-clamp: 2
        &:hover,
        &:focus,
        &.active
            color: white
            background: ins-background-blue
            header
                color: white
            .ins-slug,
            .ins-search-preview
            .search-keyword
                color: white
        .search-keyword
            color: var(--color-link)
            font-size: 14px
            border-bottom: 1px dashed #555
            font-weight: bold
            font-style: italic

.ins-empty
    padding: 18px 15px
    color: ins-text-grey
    border-bottom: 1px solid ins-border-grey
