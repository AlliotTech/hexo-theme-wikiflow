#article-nav
    display: grid
    gap: 12px
    grid-template-columns: 1fr
    margin: 28px var(--space-article) var(--space-article)
    padding-top: 16px
    border-top: 1px solid color-border
    @media mq-normal
        grid-template-columns: repeat(2, minmax(0, 1fr))

.article-nav-link-wrap
    display: flex
    align-items: center
    gap: 12px
    box-sizing: border-box
    min-width: 0
    min-height: 64px
    padding: 12px 14px
    text-decoration: none
    color: var(--color-grey)
    border: 1px solid var(--color-border)
    border-radius: var(--radius-default)
    background: var(--color-surface)
    transition: 0.2s ease
    &:hover
        color: var(--color-link)
        border-color: var(--color-link)
        background: var(--color-background)
        text-decoration: none
        .article-nav-title
            color: var(--color-link)
    &:focus-visible
        text-decoration: none
    &:only-child
        @media mq-normal
            grid-column: 1 / -1

#article-nav-newer
    text-align: left

#article-nav-older
    text-align: left
    @media mq-normal
        justify-content: flex-end
        text-align: right
        .article-nav-content
            align-items: flex-end

.article-nav-caption
    display: block
    margin-bottom: 6px
    letter-spacing: 0
    line-height: 1.2
    font-weight: bold
    color: var(--color-grey)
    font-size: 0.78em
    text-transform: none

.article-nav-title
    display: -webkit-box
    overflow: hidden
    margin-top: 0
    color: color-default
    font-size: 0.95em
    line-height: 1.5
    -webkit-box-orient: vertical
    -webkit-line-clamp: 2

.article-nav-content
    display: flex
    flex: 1 1 auto
    min-width: 0
    flex-direction: column

.article-nav-icon
    flex: 0 0 auto
    color: var(--color-grey)
    font-size: 18px
