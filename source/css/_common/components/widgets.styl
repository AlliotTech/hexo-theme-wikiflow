.widget
    @extend $base-style
    line-height: line-height
    word-wrap: break-word
    font-size: 0.9em
    ul, ol
        list-style: none
        margin: 0
        ul, ol
            margin: 0 20px
        ul
            list-style: disc
        ol
            list-style: decimal

.category-list-count
.tag-list-count
.archive-list-count
    padding-left: 5px
    color: var(--color-grey)
    font-size: 0.85em
    &:before
        content: "("
    &:after
        content: ")"

.tagcloud
    a
        display: inline-block
        margin-right: 10px
        &:before
            content: "#"

.widget-wrap
    margin: var(--space-block) 0
    background-color: color-background + 20%
    border: 4px solid var(--color-border-stretch)
    border-radius: var(--radius-default)
    padding: 20px
    h3
        line-height: 20px
        background: var(--color-meta-head)
        margin: -21px -21px 10px -21px
        padding: 0 20px
        line-height: 30px
        border: 1px solid var(--color-panel-border)
        border-radius: var(--radius-default) var(--radius-default) 0 0
        a
            margin-top: 5px
            float: right
            @media mq-mini
                display: none
            @media mq-mobile
                display: none
        a,
        span
            border-radius: var(--radius-default) var(--radius-default) 0 0
            background: color-background + 20%
            font-size: 15px
            line-height: 18px
            padding: 5px 10px
            vertical-align:bottom
            i
                font-size: 20px
                vertical-align:bottom

.widget-title
    @extend $block-caption
    margin-bottom: 0

.sidebar-panel-tabs
    display: none
    margin: var(--space-block) 0 12px
    border: 1px solid var(--color-border-stretch)
    border-radius: var(--radius-default)
    background: color-background + 20%
    padding: 4px
    gap: 4px
    @media mq-tablet
        display: flex
    @media mq-normal
        display: flex

.sidebar-panel-tab
    flex: 1
    min-width: 0
    border: 0
    border-radius: var(--radius-small)
    background: transparent
    color: var(--color-sidebar-text)
    cursor: pointer
    font-size: 13px
    line-height: 1.4
    padding: 7px 8px
    text-align: center
    transition: background 0.2s ease, color 0.2s ease
    &.is-active,
    &:hover
        background: var(--color-surface)
        color: var(--color-sidebar-text-dark)

.sidebar-panel-container
    min-height: 0
    @media mq-tablet
        flex: 1
        overflow-x: hidden
        overflow-y: auto
    @media mq-normal
        flex: 1
        overflow-x: hidden
        overflow-y: auto

.sidebar-panel
    display: none
    &.is-active
        display: block
    .widget-wrap
        margin: 0 0 20px
        &:last-child
            margin-bottom: 0

@media mq-mini
    .sidebar-panel-tabs,
    .sidebar-panel.sidebar-panel-toc
        display: none
    .sidebar-panel-container,
    .sidebar-panel.sidebar-panel-widgets
        display: contents

@media mq-mobile
    .sidebar-panel-tabs,
    .sidebar-panel.sidebar-panel-toc
        display: none
    .sidebar-panel-container,
    .sidebar-panel.sidebar-panel-widgets
        display: contents

.widget
    padding: 15px 5px
    a
        color: var(--color-sidebar-text)
        text-decoration: none
        &:hover
            color: var(--color-sidebar-text-dark)
    ul, ol, dl
        ul, ol, dl
            margin-left: 15px
            list-style: disc
    ul, ol
        list-style: none
        li,
        .category-list-child
            padding: 10px 0
            font-size: font-size
            border-bottom: none
            a
                color: var(--color-sidebar-text)
        ul, ol
            list-style: none
            li
                border: none
                &:last-child
                    padding-bottom: 0px
    ul:not(#recent-post), ol:not(#recent-post)
        li
            a
                &:before
                    color: #ccc
                    content: "\f0da"
                    font-size: 12px
                    margin-right: 6px
                    font-family: "Font Awesome 7 Free"
                    font-weight: 900
                    transition: 0.2s ease
                &:hover:before
                    color: var(--color-sidebar-text-dark)

#toTop
    @extend $block
    display: none
    cursor: pointer
    text-align: center
    width: 60px
    height: 60px
    color: var(--color-text-inverse)
    font-size: 50px
    line-height: 55px
    background: var(--color-default)
    opacity: 0.8
    border-radius: var(--radius-default)
    bottom: 20px
    margin: 20px
    position: fixed
    @media mq-mobile
        width: 52px
        height: 52px
        font-size: 34px
        line-height: 52px
    @media mq-mini
        width: 48px
        height: 48px
        font-size: 32px
        line-height: 48px

#recent-post
    li
        clearfix()
        padding: 10px 0 10px 94px
    &.no-thumbnail
        li
            padding: 10px 0px
    li
        .item-thumbnail
            opacity: 1
            float: left
            margin-left: -94px
            transition: all 0.2s ease
            .thumbnail
                width: 80px
                height: 80px
                display: block
                position: relative
                overflow: hidden
                span
                    width: 100%
                    height: 100%
                    display: block
                .thumbnail-image
                    position: absolute
                    background-size: cover
                    background-position: center
                .thumbnail-none
                    background-image: url(thumbnail-default-small)
                    background-size: 100% 100%
        .item-inner
            a
            .item-category
                font-size: 13px
                text-transform: uppercase
                a
                    color: color-link
                    &:hover
                        color: var(--color-sidebar-text-dark)
                a, .fa-solid, .fa-regular, .fa-brands
                    margin-right: 5px
            .item-title
                font-size: 15px
                a
                    color: var(--color-sidebar-text-dark)
                    transition: all 0.2s ease
            .item-date
                color: #aaa
                font-size: 13px
                text-transform: uppercase
        &:hover
            .item-thumbnail
                opacity: 0.8
            .item-title a
                color: var(--color-link)

#categories
    text-shadow: 0 1px 0 #FFFFFF
    font-size: 13px
    @media mq-mini
        order: -1
        margin: var(--space-article) 0 0
    @media mq-mobile
        order: -1
        margin: var(--space-article) 0 0
    ul
        margin-bottom: 0
        li:last-child
            padding-bottom: 0
    li
        padding: 5px 0
        ul
            padding-left: 20px
            display: none
            margin-top: 5px
        &.directory.open > ul
            display: block
        &.directory
            font-weight: bold
            & > a
                color: var(--color-sidebar-text-dark)
                &:hover
                    text-decoration: none
        &.file
            font-weight: normal
            word-wrap: break-word
            &.active > a
                font-weight: bold
        li.file
            padding-left: 10px
            word-wrap: break-word
        a,
        a:hover
            display: block
            text-decoration: none
        a:focus:before
            content: "↪"
            float: left
            margin-left: -13px
            font-weight: bold
            color: var(--color-sidebar-text-dark)

.category-tree-loading
    min-height: 1px

.category-tree-fallback
    margin: 0
    a
        color: var(--color-sidebar-text-dark)
        text-decoration: none

.widget-mobile-toggle
    display: none
    align-items: center
    justify-content: center
    width: 32px
    height: 32px
    float: right
    margin: -1px 0 0 8px
    border: 1px solid var(--color-border)
    border-radius: var(--radius-default)
    background: var(--color-surface)
    color: var(--color-sidebar-text-dark)
    cursor: pointer
    &:before
        content: '\f107'
        font-family: 'Font Awesome 7 Free'
        font-weight: 900
    &[aria-expanded="true"]:before
        content: '\f106'
    @media mq-mini
        display: inline-flex
    @media mq-mobile
        display: inline-flex

.widget-body
    display: block

@media mq-mini
    .widget-wrap.is-collapsed .widget-body
        display: none

@media mq-mobile
    .widget-wrap.is-collapsed .widget-body
        display: none
