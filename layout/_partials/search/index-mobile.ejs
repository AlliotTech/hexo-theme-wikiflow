<% var search = theme.search || {}; %>
<% if (search.insight) { %>
    <button type="button" class="search-form-trigger mobile-search-trigger" aria-label="<%= __('index.search') %>" title="<%= __('index.search') %>"></button>
<% } else { %>
    <%- search_form({text: __('index.search')}) %>
<% } %>
