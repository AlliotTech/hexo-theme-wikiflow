<div class="ins-search">
    <div class="ins-search-mask"></div>
    <div class="ins-search-container" role="dialog" aria-modal="true" aria-label="<%= __('index.search') %>">
        <div class="ins-input-wrapper">
            <input type="text" class="ins-search-input" placeholder="<%= __('insight.hint') %>" aria-label="<%= __('index.search') %>" />
            <button type="button" class="ins-close ins-selectable" aria-label="<%= __('insight.close') %>"><i class="fa-solid fa-circle-xmark"></i></button>
        </div>
        <div class="ins-section-wrapper">
            <div class="ins-section-container"></div>
        </div>
    </div>
</div>
<%
    var insightConfig = JSON.stringify({
        TRANSLATION: {
            POSTS: __('insight.posts'),
            PAGES: __('insight.pages'),
            CATEGORIES: __('insight.categories'),
            TAGS: __('insight.tags'),
            UNTITLED: __('insight.untitled'),
            EMPTY: __('insight.empty'),
            ERROR: __('insight.error')
        },
        ROOT_URL: config.root || '/',
        CONTENT_URL: url_for('/content.json'),
        SCRIPT_URL: url_for('/js/insight.js')
    }).replace(/</g, '\\u003c')
        .replace(/>/g, '\\u003e')
        .replace(/&/g, '\\u0026')
        .replace(/\u2028/g, '\\u2028')
        .replace(/\u2029/g, '\\u2029');
%>
<script>
(function (window) {
    window.INSIGHT_CONFIG = <%- insightConfig %>;
})(window);
</script>
