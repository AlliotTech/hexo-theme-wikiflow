<div id="search-form-wrap">
<% var search = theme.search || {}; %>
<% if (search.insight) { %>
    <button type="button" class="search-form-trigger" aria-label="<%= __('index.search') %>" title="<%= __('index.search') %>"></button>
<% } else { %>
    <%- search_form({ button: ' ', text: __('index.search') }) %>
<% } %>
</div>
<% if (search.insight) { %>
    <%- partial('_partials/search/insight') %>
<% } %>
