<% var tocVariant = typeof variant !== 'undefined' ? variant : 'mobile'; %>
<% var tocTitle = __('article.catalogue'); %>
<% var resolvedTocContent = typeof tocContent !== 'undefined' ? tocContent : wikiflow_toc(post); %>
<% var hasTocContent = resolvedTocContent && String(resolvedTocContent).trim(); %>
<% if (post && post.toc !== false && hasTocContent) { %>
    <% if (tocVariant === 'sidebar') { %>
        <nav class="post-toc post-toc-sidebar widget-wrap" aria-label="<%= tocTitle %>">
            <h3 class="widget-title">
                <span><%= tocTitle %></span>
            </h3>
            <div class="post-toc-body widget">
                <%- resolvedTocContent %>
            </div>
        </nav>
    <% } else { %>
        <details class="post-toc post-toc-mobile">
            <summary class="post-toc-title"><%= tocTitle %></summary>
            <div class="post-toc-body">
                <%- resolvedTocContent %>
            </div>
        </details>
    <% } %>
<% } %>
