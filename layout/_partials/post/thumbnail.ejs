<a href="<%= url_for((post.link ? post.link : post.path)) %>" class="thumbnail">
    <% var thumbnailUrl = thumbnail(post) %>
    <% if (thumbnailUrl) { %>
        <img src="<%= url_for(thumbnailUrl) %>" alt="<%= post.title || __('insight.untitled') %>" class="thumbnail-image" loading="lazy" decoding="async" />
    <% } else { %>
        <span class="thumbnail-image thumbnail-none"></span>
    <% } %>
</a>
