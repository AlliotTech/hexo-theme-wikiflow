<% var links = theme.links || {}; %>
<% var linkNames = Object.keys(links).filter(function(name) { return links[name]; }); %>
<% if (linkNames.length) { %>
    <div class="widget-wrap widget-list">
        <h3 class="widget-title"><span><%= __('widget.links') %></span></h3>
        <div class="widget">
            <ul>
                <% linkNames.forEach(function(name) { %>
                    <li>
                        <a href="<%= url_for(links[name]) %>"><%= name %></a>
                    </li>
                <% }); %>
            </ul>
        </div>
    </div>
<% } %>
