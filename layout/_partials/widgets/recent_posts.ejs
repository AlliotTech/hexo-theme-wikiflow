<% if (site.posts.length) { %>
    <% var thumbnailEnabled = !!(theme.recent_posts && theme.recent_posts.thumbnail); %>
    <div class="widget-wrap">
        <h3 class="widget-title"><span><%= __('widget.recents') %></span></h3>
        <div class="widget">
            <ul id="recent-post" class="<%= (thumbnailEnabled?'':'no-thumbnail') %>">
                <% site.posts.sort('date', -1).limit(5).each(function(post) { %>
                    <li>
                        <% if(thumbnailEnabled) { %>
                        <div class="item-thumbnail">
                            <%- partial('_partials/post/thumbnail', {post: post}) %>
                        </div>
                        <% } %>
                        <div class="item-inner">
                            <p class="item-category"><%- partial('_partials/post/taxonomy-links', {
                                items: post.categories,
                                class_name: 'article-category-link',
                                separator: wikiflow_icon('angle-right')
                            }) %></p>
                            <p class="item-title"><a href="<%= url_for((post.link?post.link:post.path)) %>" class="title"><%= post.title %></a></p>
                            <p class="item-date"><time datetime="<%= date_xml(post.date) %>" itemprop="datePublished"><%= date(post.date) %></time></p>
                        </div>
                    </li>
                <% }) %>
            </ul>
        </div>
    </div>
<% } %>
