<% if (site.categories.length) { %>
    <%
        var categoryConfig = theme.category || {};
        var categoryMode = categoryConfig.mode || 'external';
        var categoryExternal = categoryMode !== 'full';
        var categoryPerExpand = !!categoryConfig.expand_all;
        var categoryTreeUrl = categoryExternal ? wikiflow_category_tree_url() : '';
        var categoriesTree = categoryExternal ? null : wikiflow_category_tree();
        var categoriesUrl = url_for(config.category_dir || 'categories');
        var categoryTocContent = typeof sidebarTocContent !== 'undefined' ? sidebarTocContent : '';
        var hasCategoryToc = categoryTocContent && String(categoryTocContent).trim();
        var outlineLabel = __('article.outline');
        if (outlineLabel === 'article.outline') outlineLabel = __('article.catalogue');
    %>
    <div class="widget-wrap<%- hasCategoryToc ? ' sidebar-category-panel sidebar-panel-active-categories' : '' %>" id="categories"
        data-category-mode="<%= categoryExternal ? 'external' : 'full' %>"
        data-tree-src="<%= categoryTreeUrl %>"
        data-current-path="<%= url_for(page.path || '') %>"
        data-root-url="<%= url_for('/') %>"
        data-fallback-url="<%= categoriesUrl %>"
        data-fallback-label="<%= __('widget.categories') %>"
        data-expand-all="<%= categoryPerExpand ? 'true' : 'false' %>">
        <h3 class="widget-title">
            <% if (hasCategoryToc) { %>
                <span class="sidebar-panel-tablist" role="tablist" aria-label="<%= __('widget.categories') %>">
                    <button class="sidebar-panel-tab is-active" type="button" role="tab" data-sidebar-panel="categories" aria-controls="categories-body" aria-selected="true">
                        <%= __('widget.categories') %>
                    </button>
                    <button class="sidebar-panel-tab" type="button" role="tab" data-sidebar-panel="outline" aria-controls="categories-outline-body" aria-selected="false">
                        <%= outlineLabel %>
                    </button>
                </span>
            <% } else { %>
                <span><%= __('widget.categories') %></span>
            <% } %>
            &nbsp;
            <a id="allExpand" href="#" aria-label="<%= __('widget.categories') %>">
                <i class="fa-solid fa-angles-<%- categoryPerExpand ? 'up' : 'down' %> fa-2x"></i>
            </a>
            <button class="widget-mobile-toggle" type="button" aria-controls="categories-body" aria-expanded="false" aria-label="<%= __('widget.categories') %>"></button>
        </h3>
        <div class="widget-body<%- hasCategoryToc ? ' sidebar-panel sidebar-panel-categories is-active' : '' %>" id="categories-body"<% if (hasCategoryToc) { %> role="tabpanel" aria-hidden="false"<% } %>>

        <% if (categoryExternal) { %>
            <div class="category-tree-loading" data-role="category-tree-status" aria-live="polite"></div>
            <noscript>
                <p class="category-tree-fallback">
                    <a href="<%= categoriesUrl %>"><%= __('widget.categories') %></a>
                </p>
            </noscript>
        <% } else { %>
        <%
            function visitTreePosts(branch, perExpand) {
        %>
            <ul class="unstyled category-tree">
                <% if (branch.children && branch.children.length) { %>
                    <% branch.children.forEach(function(category) { %>
                        <% var isOpen = perExpand || category.selected; %>
                        <li class="directory<%- isOpen ? ' open' : '' %>">
                            <a href="#" data-role="directory" aria-expanded="<%- isOpen ? 'true' : 'false' %>">
                                <i class="fa-solid fa-folder<%- isOpen ? '-open' : '' %>"></i>
                                &nbsp;
                                <%= category.name %>
                            </a>
                            <% visitTreePosts(category, perExpand); %>
                        </li>
                    <% }); %>
                <% } %>
                <% if (branch.articles && branch.articles.length) { %>
                    <% branch.articles.forEach(function(post) { %>
                        <li class="file<%- (is_post() && post._id === page._id) ? ' active' : '' %>">
                            <a href="<%= url_for(post.path) %>"><%= post.title || __('insight.untitled') %></a>
                        </li>
                    <% }); %>
                <% } %>
            </ul>
        <%
            }

            visitTreePosts(categoriesTree, categoryPerExpand);
        %>
        <% } %>
        </div>
        <% if (hasCategoryToc) { %>
            <div class="widget-body sidebar-panel sidebar-panel-outline post-toc post-toc-sidebar" id="categories-outline-body" role="tabpanel" aria-hidden="true">
                <div class="post-toc-body">
                    <%- categoryTocContent %>
                </div>
            </div>
        <% } %>
    </div>
<% } %>
