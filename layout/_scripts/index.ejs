<%- partial('_third-party/comments/scripts', { page: page }) %>
<%- partial('_third-party/index') %>

<%
var wikiflowUiConfig = JSON.stringify({
    CLOSE_IMAGE: __('article.close_image'),
    COPY_CODE: __('article.copy_code'),
    CODE_COPIED: __('article.code_copied'),
    COPY_FAILED: __('article.copy_failed'),
    ICON_SPRITE_URL: wikiflow_icon_sprite_url()
}).replace(/</g, '\\u003c')
    .replace(/>/g, '\\u003e')
    .replace(/&/g, '\\u0026')
    .replace(/\u2028/g, '\\u2028')
    .replace(/\u2029/g, '\\u2029');
%>
<script>window.WIKIFLOW_UI = <%- wikiflowUiConfig %>;</script>

<!-- Custom Scripts -->
<%- js('js/main') %>
<% if (theme.share && (is_home() || is_post() || page.layout === 'page')) { %>
    <%- js('js/share') %>
<% } %>
