<%
    var vendors = theme.vendors || {};
    var styles = [
        { key: 'fontawesome', local: 'libs/font-awesome/css/font-awesome.min' },
        { key: 'open_sans', local: 'libs/open-sans/styles' },
        { key: 'source_code_pro', local: 'libs/source-code-pro/styles' }
    ];

    styles.forEach(function (vendor) {
        var value = Object.prototype.hasOwnProperty.call(vendors, vendor.key) ? vendors[vendor.key] : 'local';
        if (value === false || value === 'false' || value === 'off') return;
        if (!value || value === true || value === 'local') {
%>
    <%- css(vendor.local) %>
<%
        } else {
%>
    <link rel="stylesheet" href="<%- value %>" />
<%
        }
    });
%>
