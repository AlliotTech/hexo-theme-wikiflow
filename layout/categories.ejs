<% var categoryGroups = wikiflow_category_groups({ childLimit: 6, postLimit: 4 }); %>
<section class="layout-wrap category-index">
    <div class="layout-title">
        <span><%= page.title %></span>
    </div>
    <div class="layout-wrap-inner category-index-grid">
        <% if (categoryGroups.length) { %>
            <% categoryGroups.forEach(function(group) { %>
                <section class="category-index-group">
                    <header class="category-index-header">
                        <h2>
                            <a href="<%= url_for(group.path) %>"><%= group.name %></a>
                        </h2>
                        <span class="category-index-count"><%= group.length %></span>
                    </header>
                    <% if (group.children.length) { %>
                        <ul class="category-index-links">
                            <% group.children.forEach(function(child) { %>
                                <li>
                                    <a href="<%= url_for(child.path) %>"><%= child.name %></a>
                                    <span class="category-list-count"><%= child.length %></span>
                                </li>
                            <% }); %>
                        </ul>
                    <% } %>
                    <% if (group.posts.length) { %>
                        <ul class="category-index-posts">
                            <% group.posts.forEach(function(post) { %>
                                <li><a href="<%= url_for(post.path) %>"><%= post.title || __('insight.untitled') %></a></li>
                            <% }); %>
                        </ul>
                    <% } %>
                </section>
            <% }); %>
        <% } else { %>
            <p class="layout-empty"><%= __('layout.no_categories') %></p>
        <% } %>
    </div>
</section>
